{
  "name": "azure-storage",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "start": "node src/index.js",
    "start:dev": "nodemon src/index.js",
    "start:lwatch": "nodemon -L src/index.js",
    "start:debug": "nodemon --inspect src/index.js",
    "docker:build:dev": "docker build --file Dockerfile-dev -t azure-storage:dev .",
    "docker:build:prod": "docker build --file Dockerfile-prod -t azure-storage:1.0.0 .",
    "docker:tag:azure": "docker tag azure-storage:1.0.0 tftshflixtube.azurecr.io/azure-storage:1.0.0",
    "docker:push:azure": "docker push tftshflixtube.azurecr.io/azure-storage:1.0.0",
    "docker:run": "docker run -d -e PORT=80 -p 3000:80 --name azure-storage azure-storage",
    "docker:stop": "docker stop azure-storage",
    "kubectl:apply:desktop": "kubectl apply -f scripts/deploy-desktop.yaml",
    "kubectl:delete:desktop": "kubectl delete -f scripts/deploy-desktop.yaml",
    "kubectl:apply:azure": "kubectl apply -f scripts/deploy-azure.yaml",
    "kubectl:delete:azure": "kubectl delete -f scripts/deploy-azure.yaml"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}